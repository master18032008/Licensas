import os
import json
import requests
import time

pasta_atual = os.path.dirname(os.path.realpath(__file__))

print("=== INICIANDO MAPEAMENTO VIA STEAM STORE API (100% REAL) ===")

# 1. Puxa os IDs locais dos seus arquivos .lua
app_ids = []
for arquivo in os.listdir(pasta_atual):
    if arquivo.endswith('.lua'):
        id_limpo = arquivo.replace('.lua', '').strip()
        if id_limpo.isdigit():
            app_ids.append(id_limpo)

total_jogos = len(app_ids)
print(f"Encontrados {total_jogos} arquivos locais para tradução.")
print("Buscando dados diretamente na loja da Steam... Aguarde.\n")

banco_de_jogos = []
headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}

for i, app_id in enumerate(app_ids, start=1):
    nome_jogo = f"Steam App {app_id}" # Nome padrão caso falhe
    
    try:
        # Consulta a API pública de detalhes do produto na loja
        url_loja = f"https://store.steampowered.com/api/appdetails?appids={app_id}&l=brazilian"
        resposta = requests.get(url_loja, headers=headers, timeout=10)
        
        if resposta.ok:
            dados = resposta.json()
            # A Steam responde no formato {"ID": {"success": true/false, "data": {...}}}
            if dados and dados.get(app_id) and dados[app_id].get('success'):
                nome_jogo = dados[app_id]['data']['name']
        
    except Exception as e:
        print(f"\n[Erro no ID {app_id}]: {e}")
    
    url_imagem = f"https://shared.fastly.steamstatic.com/store_images/apps/{app_id}/header.jpg"
    
    banco_de_jogos.append({
        "id": app_id,
        "nome": nome_jogo,
        "imagem": url_imagem
    })
    
    # Printa o progresso na tela para você acompanhar
    print(f"[{i}/{total_jogos}] ID: {app_id} -> {nome_jogo}")
    
    # PEQUENA PAUSA OBRIGATÓRIA PARA A STEAM NÃO BLOQUEAR SEU IP
    time.sleep(0.3)

# 4. Salva o arquivo final estruturado
arquivo_saida = os.path.join(pasta_atual, 'jogos.json')
with open(arquivo_saida, 'w', encoding='utf-8') as f:
    json.dump(banco_de_jogos, f, ensure_ascii=False, indent=4)

print("\n=== PROCESSO FINALIZADO ===")
print(f"O arquivo mestre '{arquivo_saida}' foi gerado com sucesso!")
